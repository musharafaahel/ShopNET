@model ShopNET.Models.Product

@{
    ViewData["Title"] = Model.Name;
}

<div class="row">
    <div class="col-md-6">
        <div class="bg-light rounded d-flex align-items-center justify-content-center" style="height:350px;">
            <span class="text-muted">No image yet</span>
        </div>
    </div>
    <div class="col-md-6">
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/Product">Products</a></li>
                <li class="breadcrumb-item active">@Model.Name</li>
            </ol>
        </nav>

        <h2>@Model.Name</h2>
        <p class="text-muted">@Model.Description</p>

        <h3 class="text-success my-3">$@Model.Price</h3>

        <p class="text-muted">
            @if (Model.Stock > 0)
            {
                <span class="badge bg-success">In Stock (@Model.Stock units)</span>
            }
            else
            {
                <span class="badge bg-danger">Out of Stock</span>
            }
        </p>

        <button class="btn btn-dark btn-lg w-100 mt-3">Add to Cart</button>
        <a href="/Product" class="btn btn-outline-secondary w-100 mt-2">← Back to Products</a>
    </div>
</div>