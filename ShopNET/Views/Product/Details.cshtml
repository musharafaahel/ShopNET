@model ShopNET.Models.Product


@{
    ViewData["Title"] = Model.Name;
}

<div style="margin:30px; max-width:600px;">

    <a href="/Product" style="color:gray;">← Back to Products</a>

    <h2 style="margin-top:20px;">@Model.Name</h2>
    <p style="color:gray;">@Model.Description</p>

    <div style="margin:20px 0;">
        <span style="font-size:28px; font-weight:bold;">$@Model.Price</span>
    </div>

    <p>Stock available: @Model.Stock</p>

    <button style="background:#007bff; color:white; padding:10px 20px; border:none; border-radius:5px; cursor:pointer;">
        Add to Cart
    </button>

</div>
