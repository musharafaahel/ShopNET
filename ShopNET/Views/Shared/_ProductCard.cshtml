@model ShopNET.Models.Product

<div class="card h-100 shadow-sm">
    <div class="card-body">
        <h5 class="card-title">@Model.Name</h5>
        <p class="card-text text-muted">@Model.Description</p>
        <p class="card-text">
            <span class="fs-4 fw-bold text-success">$@Model.Price</span>
        </p>
        <small class="text-muted">Stock: @Model.Stock units</small>
    </div>
    <div class="card-footer bg-white border-0 pb-3">
        <a href="/Product/Details/@Model.Id" class="btn btn-dark w-100">View Details</a>
    </div>
</div>